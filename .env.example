# Copy this file to .env and fill in your values before running setup or docker compose.
# The .env file is git-ignored and never committed.

# Secret used to sign and verify JWT tokens. Change this in any non-local environment.
JWT_SECRET=dev-secret-key

# Allowed CORS origin. Set to your frontend URL.
CORS_ALLOW_ORIGIN=http://localhost:4200

# PostgreSQL credentials (shared across all services in the full stack).
DB_NAME=apidb
DB_USER=apiuser_test
DB_PASS=apipass_test
